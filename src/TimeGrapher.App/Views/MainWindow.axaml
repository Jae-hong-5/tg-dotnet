<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TimeGrapher.App.Views.MainWindow"
        Title="TimeGrapher"
        Width="1280" Height="750"
        MinWidth="900" MinHeight="560">
  <DockPanel>
    <Border DockPanel.Dock="Bottom" Height="24" Background="#F0F0F0" BorderBrush="#C0C0C0" BorderThickness="0,1,0,0">
      <TextBlock Name="StatusBarText" VerticalAlignment="Center" Margin="6,0,0,0" Text="" />
    </Border>

    <Grid ColumnDefinitions="300,*" RowDefinitions="30,*">
      <ScrollViewer Grid.Column="0" Grid.RowSpan="2"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Background="#FAFAFA">
        <StackPanel Margin="8" Spacing="8">
          <Border BorderBrush="#808080" BorderThickness="1" Background="Transparent" Padding="8">
            <StackPanel Spacing="8">
              <TextBlock Name="RunParamLabel"
                         FontSize="14" FontWeight="Bold" TextDecorations="Underline"
                         TextAlignment="Center" Text="Run Parameters" />
              <Grid ColumnDefinitions="112,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="7" ColumnSpacing="8">
                <TextBlock Name="GainLabel" Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="Gain" />
                <Slider Name="MicrophoneHorizontalSlider" Grid.Row="0" Grid.Column="1"
                        Minimum="0" Maximum="1000" Value="100" Orientation="Horizontal" />

                <ComboBox Name="InputDeviceComboBox" Grid.Row="1" Grid.ColumnSpan="2"
                          FontWeight="Bold" />

                <Button Name="RefreshPushButton" Grid.Row="2" Grid.Column="0"
                        MinWidth="72" FontWeight="Bold" Content="Refresh" />

                <TextBlock Name="SampleRateLabel" Grid.Row="3" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="Sample Rate" />
                <ComboBox Name="SampleRatesComboBox" Grid.Row="3" Grid.Column="1"
                          FontWeight="Bold" />

                <TextBlock Name="ModeLabel" Grid.Row="4" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="Mode" />
                <ComboBox Name="ModeComboBox" Grid.Row="4" Grid.Column="1"
                          FontWeight="Bold" />

                <TextBlock Name="AveragingPeriodLabel" Grid.Row="5" Grid.Column="0"
                           VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Text="Averaging Period" />
                <ComboBox Name="AveragingPeriodComboBox" Grid.Row="5" Grid.Column="1"
                          FontSize="13" FontWeight="Bold" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Name="StartPushButton" Grid.Column="0"
                        MinWidth="72" FontWeight="Bold" Content="Start" />
                <Button Name="StopPushButton" Grid.Column="2"
                        MinWidth="72" FontWeight="Bold" Content="Stop" />
              </Grid>
            </StackPanel>
          </Border>

          <Border BorderBrush="#808080" BorderThickness="1" Background="Transparent" Padding="8">
            <StackPanel Spacing="8">
              <TextBlock Name="WatchParamLabel"
                         FontSize="14" FontWeight="Bold" TextDecorations="Underline"
                         TextAlignment="Center" Text="Watch Parameters" />
              <Grid ColumnDefinitions="106,*" RowDefinitions="Auto,Auto" RowSpacing="7" ColumnSpacing="8">
                <TextBlock Name="WatchBphLabel" Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="BPH" />
                <ComboBox Name="BPHComboBox" Grid.Row="0" Grid.Column="1"
                          FontWeight="Bold" />

                <TextBlock Name="LiftAngleLabel" Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Text="Lift Angle" />
                <NumericUpDown Name="LiftAngleSpinBox" Grid.Row="1" Grid.Column="1"
                               FontSize="13" FontWeight="Bold" FormatString="0'°'"
                               Minimum="30" Maximum="70" Increment="1" Value="30" />
              </Grid>
            </StackPanel>
          </Border>

          <Border BorderBrush="#808080" BorderThickness="1" Background="Transparent" Padding="8">
            <StackPanel Spacing="8">
              <TextBlock Name="SimParamLabel"
                         FontSize="14" FontWeight="Bold" TextDecorations="Underline"
                         TextAlignment="Center" Text="Simulation Parameters" />
              <Grid ColumnDefinitions="106,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="7" ColumnSpacing="8">
                <TextBlock Name="SimBphLabel" Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="BPH" />
                <ComboBox Name="SimBPHComboBox" Grid.Row="0" Grid.Column="1"
                          FontWeight="Bold" />

                <TextBlock Name="SimErrorRateLabel" Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="Error Rate" />
                <NumericUpDown Name="SimErrorRateSpinBox" Grid.Row="1" Grid.Column="1"
                               FontSize="13" FontWeight="Bold" FormatString="0' s/d'"
                               Minimum="-999" Maximum="999" Increment="1" Value="0" />

                <TextBlock Name="SimAmpLabel" Grid.Row="2" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="Amplitude" />
                <NumericUpDown Name="SimAmplitudeSpinBox" Grid.Row="2" Grid.Column="1"
                               FontSize="13" FontWeight="Bold" FormatString="0'°'"
                               Minimum="100" Maximum="360" Increment="1" Value="300" />

                <TextBlock Name="SimBeatErrorLabel" Grid.Row="3" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="Beat Error" />
                <NumericUpDown Name="SimBeatErrorSpinBox" Grid.Row="3" Grid.Column="1"
                               FontWeight="Bold" FormatString="0.0' ms'"
                               Minimum="-10" Maximum="10" Increment="0.1" Value="0" />

                <CheckBox Name="RealisticCheckBox" Grid.Row="4" Grid.ColumnSpan="2"
                          FontWeight="Bold" Content="Realistic" IsChecked="True" />
              </Grid>
            </StackPanel>
          </Border>

          <Border BorderBrush="#808080" BorderThickness="1" Background="Transparent" Padding="8">
            <StackPanel Spacing="8">
              <TextBlock Name="MiscLabel"
                         FontSize="14" FontWeight="Bold" TextDecorations="Underline"
                         TextAlignment="Center" Text="Misc. Parameters" />
              <Grid ColumnDefinitions="132,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="7" ColumnSpacing="8">
                <TextBlock Name="HighPassLabel" Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="High Pass Cutoff" />
                <TextBox Name="HighLineEdit" Grid.Row="0" Grid.Column="1"
                         Text="200" />

                <TextBlock Name="ScopeScaleLabel" Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center" FontWeight="Bold" Text="Scope Scale" />
                <NumericUpDown Name="ScopeScaleSpinBox" Grid.Row="1" Grid.Column="1"
                               Minimum="1" Maximum="8" Increment="1" Value="2" />

                <CheckBox Name="UseConsetCheckBox" Grid.Row="2" Grid.ColumnSpan="2"
                          FontWeight="Bold" Content="C Event Use Onset Amplitude" />
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <TextBlock Name="Results" Grid.Column="1" Grid.Row="0" Margin="8,0,10,0"
                 FontSize="16" FontWeight="Bold" TextAlignment="Center"
                 VerticalAlignment="Center"
                 Text="RATE ------ s/d  AMPLITUDE ---°  BEAT ERROR ---- ms BEAT ----- bph" />

      <TabControl Name="GraphicsTabWidget" Grid.Column="1" Grid.Row="1" Margin="8,3,10,10" />
    </Grid>
  </DockPanel>
</Window>
